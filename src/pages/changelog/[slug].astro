---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChangelogHeader from '../../components/changelog/ChangelogHeader.astro';
import ChangelogMeta from '../../components/changelog/ChangelogMeta.astro';
import ChangelogContent from '../../components/changelog/ChangelogContent.astro';

export async function getStaticPaths() {
	const entries = await getCollection('changelog');

	const sorted = [...entries].sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

	return sorted.map((entry) => ({
		params: { slug: entry.id },
		props: {
			entry,
			sorted,
		},
	}));
}

const { entry, sorted } = Astro.props;

const index = sorted.findIndex((e) => e.id === entry.id);
const previous = index > 0 ? sorted[index - 1] : null;
const next = index < sorted.length - 1 ? sorted[index + 1] : null;
---

<BaseLayout title={`${entry.data.version} | Inboxt`}>
	<ChangelogHeader />

	<section>
		<div class="grid grid-cols-1 gap-6 lg:grid-cols-[200px_1fr] lg:gap-10">
			<ChangelogMeta entry={entry} showBack />

			<ChangelogContent>
				<Fragment set:html={entry.rendered?.html ?? ''} />

				<nav class="mt-20">
					<div class="grid gap-10 sm:grid-cols-2">
						{
							previous ? (
								<a
									href={`/changelog/${previous.id}`}
									class="group block h-full rounded-lg border border-(--color-border) px-4 py-4 no-underline transition-colors hover:bg-(--color-surface)"
								>
									<div class="mb-1 text-xs text-(--color-muted)">
										Previous release
									</div>

									<div class="font-medium text-(--color-text)">
										{previous.data.date.toLocaleDateString('en-US', {
											year: 'numeric',
											month: 'long',
											day: 'numeric',
										})}
									</div>

									<div class="mt-1 text-sm text-(--color-muted)">
										{previous.data.version} · {previous.data.tag}
									</div>
								</a>
							) : (
								<div />
							)
						}

						{
							next ? (
								<a
									href={`/changelog/${next.id}`}
									class="group block h-full rounded-lg border border-(--color-border) px-4 py-4 text-right no-underline transition-colors hover:bg-(--color-surface)"
								>
									<div class="mb-1 text-xs text-(--color-muted)">
										Next release
									</div>

									<div class="font-medium text-(--color-text)">
										{next.data.date.toLocaleDateString('en-US', {
											year: 'numeric',
											month: 'long',
											day: 'numeric',
										})}
									</div>

									<div class="mt-1 text-sm text-(--color-muted)">
										{next.data.version} · {next.data.tag}
									</div>
								</a>
							) : (
								<div />
							)
						}
					</div>
				</nav>
			</ChangelogContent>
		</div>
	</section>
</BaseLayout>
