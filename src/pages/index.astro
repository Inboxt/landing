---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Inboxt — Save it now. Read it later."
	description="Your inbox for the internet — save articles, newsletters, and web content."
>
	<section>
		<div class="mx-auto max-w-6xl px-4 pt-10 pb-10 sm:px-6 lg:px-8 lg:pt-14 lg:pb-16">
			<div class="mb-12 max-w-2xl space-y-5">
				<div class="space-y-1">
					<h1 class="text-4xl leading-tight font-semibold tracking-tight text-balance">
						Save it now. Read it later.
					</h1>

					<p class="max-w-xl text-lg text-(--color-muted)">
						Your inbox for the internet - save articles, newsletters, and web content
						and read them anywhere.
					</p>
				</div>

				<a
					href="/signin"
					class="bg-primary-0 dark:bg-primary-6 dark:text-primary-0 text-primary-9 dark:hover:bg-primary-8 hover:bg-primary-1 focus-visible:ring-primary-2 inline-flex h-10 items-center justify-center rounded-md border border-transparent px-6 text-sm font-semibold shadow-none transition-colors duration-150 focus-visible:ring-2 focus-visible:outline-none"
				>
					Get Started
				</a>
			</div>

			<div class="min-h-400"></div>
		</div>
	</section>
</BaseLayout>
