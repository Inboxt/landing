---
import BaseLayout from '../layouts/BaseLayout.astro';
import Features from '../components/Features.astro';
---

<BaseLayout
	title="Inboxt — Save it now. Read it later."
	description="Your inbox for the internet — save articles, newsletters, and web content."
>
	<section>
		<div class="mx-auto max-w-6xl px-4 pt-10 pb-10 sm:px-6 lg:px-8 lg:pt-14 lg:pb-16">
			<div class="mb-10 max-w-2xl space-y-5">
				<div class="space-y-1">
					<h1 class="text-4xl leading-tight font-semibold tracking-tight text-balance">
						Save it now. Read it later.
					</h1>

					<p class="max-w-xl text-lg text-(--color-muted)">
						Your inbox for the internet — save articles, newsletters, and web content
						and read them anywhere
					</p>
				</div>

				<a
					href="/signin"
					class="bg-primary-0 dark:bg-primary-6 dark:text-primary-0 text-primary-9 dark:hover:bg-primary-8 hover:bg-primary-1 focus-visible:ring-primary-2 inline-flex h-10 items-center justify-center rounded-md border border-transparent px-6 text-sm font-semibold shadow-none transition-colors duration-150 focus-visible:ring-2 focus-visible:outline-none"
				>
					Get Started
				</a>
			</div>

			<div class="space-y-20">
				<section>
					<div
						class="mx-auto max-w-5xl overflow-hidden rounded-xl border border-(--color-border) bg-(--color-surface)"
					>
						<div
							class="flex items-center gap-2 border-b border-(--color-border) px-4 py-2"
						>
							<span class="bg-gray-4 h-2 w-2 rounded-full"></span>
							<span class="bg-gray-4 h-2 w-2 rounded-full"></span>
							<span class="bg-gray-4 h-2 w-2 rounded-full"></span>
						</div>

						<img
							src="/images/hero.png"
							alt="Inboxt app interface"
							class="block w-full dark:hidden"
							loading="eager"
							fetchpriority="high"
						/>

						<img
							src="/images/hero-dark.png"
							alt="Inboxt app interface"
							class="hidden w-full dark:block"
							loading="eager"
							fetchpriority="high"
						/>
					</div>
				</section>

				<section>
					<h2 class="text-sm font-medium tracking-wide text-(--color-muted) uppercase">
						Designed for reading
					</h2>

					<div class="mt-6 grid gap-10 sm:grid-cols-3">
						<div>
							<div class="flex items-center gap-2">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="24"
									height="24"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									class="h-4 w-4 text-(--color-muted)"
									><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
										d="M4 4m0 2a2 2 0 0 1 2 -2h2a2 2 0 0 1 2 2v1a2 2 0 0 1 -2 2h-2a2 2 0 0 1 -2 -2z"
									></path><path
										d="M4 13m0 2a2 2 0 0 1 2 -2h2a2 2 0 0 1 2 2v3a2 2 0 0 1 -2 2h-2a2 2 0 0 1 -2 -2z"
									></path><path
										d="M14 4m0 2a2 2 0 0 1 2 -2h2a2 2 0 0 1 2 2v3a2 2 0 0 1 -2 2h-2a2 2 0 0 1 -2 -2z"
									></path><path
										d="M14 15m0 2a2 2 0 0 1 2 -2h2a2 2 0 0 1 2 2v1a2 2 0 0 1 -2 2h-2a2 2 0 0 1 -2 -2z"
									></path></svg
								>
								<h3 class="font-medium text-(--color-text)">Simple by design</h3>
							</div>
							<p class="mt-2 text-sm text-(--color-muted)">
								No feeds, no algorithms, no distractions. Just a calm inbox for the
								things you want to read.
							</p>
						</div>

						<div>
							<div class="flex items-center gap-2">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="24"
									height="24"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									class="h-4 w-4 text-(--color-muted)"
									><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
										d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"
									></path></svg
								>
								<h3 class="font-medium text-(--color-text)">
									Open-source & self-hostable
								</h3>
							</div>
							<p class="mt-2 text-sm text-(--color-muted)">
								Fully open-source. Use the hosted version or run your own instance
								and keep full control of your data.
							</p>
						</div>

						<div>
							<div class="flex items-center gap-2">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="24"
									height="24"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									class="h-4 w-4 text-(--color-muted)"
									><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
										d="M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z"
									></path><path d="M4 13h3l3 3h4l3 -3h3"></path></svg
								>
								<h3 class="font-medium text-(--color-text)">
									Built for how you read today
								</h3>
							</div>
							<p class="mt-2 text-sm text-(--color-muted)">
								Save articles, newsletters, and web content from anywhere. Read them
								whenever it suits you.
							</p>
						</div>
					</div>
				</section>

				<Features />

				<section>
					<h2 class="text-sm font-medium tracking-wide text-(--color-muted) uppercase">
						Built in the open
					</h2>

					<p class="mt-6 text-lg text-(--color-text)">
						Free, open-source, and designed to stay that way.
					</p>

					<ul class="mt-6 space-y-2 text-sm text-(--color-muted)">
						<li>• Open-source and community-driven</li>
						<li>• Self-hostable with full data ownership</li>
						<li>• No ads. No tracking. No lock-in</li>
					</ul>

					<p class="mt-4 text-sm text-(--color-muted)">
						Follow progress through a public roadmap and a detailed changelog.
					</p>

					<div class="mt-4 flex flex-wrap gap-4 text-sm">
						<a
							href="https://github.com/..."
							class="text-(--color-text) underline underline-offset-4 hover:text-(--color-muted)"
						>
							GitHub
						</a>
						<a
							href="/roadmap"
							class="text-(--color-text) underline underline-offset-4 hover:text-(--color-muted)"
						>
							Roadmap
						</a>
						<a
							href="/changelog"
							class="text-(--color-text) underline underline-offset-4 hover:text-(--color-muted)"
						>
							Changelog
						</a>
						<a
							href="/docs"
							class="text-(--color-text) underline underline-offset-4 hover:text-(--color-muted)"
						>
							Documentation
						</a>
					</div>
				</section>
			</div>
		</div>
	</section>
</BaseLayout>
