---
import AppLogo from '../assets/logo.svg';
import AppLogoWhite from '../assets/logo-white.svg';
---

<div class="flex items-center gap-1">
	<img
		src={AppLogo.src}
		alt="Inboxt logo"
		width={30}
		height={30}
		class="block dark:hidden"
		loading="eager"
		fetchpriority="high"
	/>
	<img
		src={AppLogoWhite.src}
		alt="Inboxt logo"
		width={30}
		height={30}
		class="hidden dark:block"
		loading="eager"
		fetchpriority="high"
	/>

	<h1 class="text-primary-6 ml-1 text-xl font-bold">Inboxt</h1>
</div>
