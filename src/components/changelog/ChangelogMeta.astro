---
const { entry, href = null, showBack = false } = Astro.props;

const tagClasses = {
	feature: `
    bg-primary-6/10 text-primary-7 border-primary-6/20
    dark:bg-primary-6/40 dark:text-primary-1 dark:border-primary-5/50
  `,
	improvement: `
    bg-blue-500/10 text-blue-600 border-blue-500/20
    dark:bg-blue-500/30 dark:text-blue-200 dark:border-blue-400/40
  `,
	fix: `
    bg-rose-500/10 text-rose-700 border-rose-500/20
    dark:bg-rose-500/30 dark:text-rose-200 dark:border-rose-400/40
  `,
};
---

<aside class="space-y-1 self-start lg:sticky lg:top-24">
	{
		showBack && (
			<a
				href="/changelog"
				class="mb-4 inline-block text-sm text-(--color-muted) hover:underline"
			>
				← Back to changelog
			</a>
		)
	}

	{
		href ? (
			<a href={href} class="group block space-y-1">
				<time
					datetime={entry.data.date.toISOString()}
					class="block text-2xl font-semibold underline-offset-4 group-hover:underline lg:text-xl"
				>
					{entry.data.date.toLocaleDateString('en-US', {
						year: 'numeric',
						month: 'long',
						day: 'numeric',
					})}
				</time>

				<div class="text-sm text-(--color-muted) group-hover:text-(--color-text)">
					{entry.data.version}
				</div>
			</a>
		) : (
			<>
				<time
					datetime={entry.data.date.toISOString()}
					class="block text-2xl font-semibold lg:text-xl"
				>
					{entry.data.date.toLocaleDateString('en-US', {
						year: 'numeric',
						month: 'long',
						day: 'numeric',
					})}
				</time>

				<div class="text-sm text-(--color-muted)">{entry.data.version}</div>
			</>
		)
	}

	<span
		class={`inline-block rounded-full border px-2 py-0.5 text-xs ${tagClasses[entry.data.tag]}`}
	>
		{entry.data.tag}
	</span>
</aside>
